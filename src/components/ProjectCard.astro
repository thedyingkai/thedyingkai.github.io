---
interface Props {
  title: string;
  description: string;
  meta: string;
  href: string;
}
const { title, description, meta, href } = Astro.props;
---
<a class="project-card" href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noreferrer' : undefined}>
  <div class="card-meta"><span>{meta}</span></div>
  <h3>{title}</h3>
  <p>{description}</p>
</a>
