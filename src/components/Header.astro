---
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '文章' },
  { href: '/about/', label: '关于' },
  { href: 'https://github.com/thedyingkai', label: 'GitHub' }
];
---
<header class="topbar">
  <div class="wrap topbar__inner">
    <a class="brand" href="/" aria-label="thedyingkai home">
      <span class="brand__mark">thedyingkai<span class="brand__dot">.</span></span>
      <span class="brand__sub">Notebook</span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={item.href !== 'https://github.com/thedyingkai' && path === item.href ? 'page' : undefined}
          target={item.href.startsWith('http') ? '_blank' : undefined}
          rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
