---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'thedyingkai',
  description = 'Personal blog, notes and projects.'
} = Astro.props;

const pageTitle = title === 'thedyingkai' ? title : `${title} · thedyingkai`;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9fafc" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="app-shell">
      <Header />
      <main class="app-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
